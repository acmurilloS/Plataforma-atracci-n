# ─────────────────────────────────────────────────────────────────────
# Variables de entorno para BUILD DE PRODUCCIÓN.
#
# Copiar este archivo a `.env.production` (gitignored) y llenar con los
# valores REALES del proyecto Firebase de producción.
#
# Cómo obtener los valores:
#   1. Firebase Console → tu proyecto → ⚙ Configuración del proyecto
#   2. Pestaña "General" → sección "Tus apps" → ícono Web </>
#   3. Si no tienes app web aún, crear una (Nombre: "Plataforma EQUITEL Prod")
#   4. Firebase mostrará el objeto `firebaseConfig` — copiar cada campo
# ─────────────────────────────────────────────────────────────────────

# DEBE quedar en false para que la app apunte a Firebase real, no a emulador.
VITE_USE_EMULATORS=false

# Credenciales del proyecto Firebase real
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Turnstile (CAPTCHA del acceso por cédula).
#   1. Panel de Cloudflare → Turnstile → Add site → copiar la "Site Key" (pública)
#   2. La "Secret Key" NO va aquí: se siembra como secreto TURNSTILE_SECRET en
#      las Cloud Functions (Secret Manager), nunca en el frontend.
VITE_TURNSTILE_SITE_KEY=
