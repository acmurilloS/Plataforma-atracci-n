rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function signedIn() { return request.auth != null; }
    function rol() { return request.auth.token.rol; }
    function isAdmin() { return signedIn() && rol() == 'admin'; }
    function isCoord() { return signedIn() && rol() == 'coordinador'; }
    function isGH() { return signedIn() && rol() == 'gh'; }
    function isLider() { return signedIn() && rol() == 'lider'; }
    function isAnalista() { return signedIn() && rol() == 'analista'; }
    function isApoyo() { return signedIn() && rol() == 'apoyo'; }
    function staff() { return isAdmin() || isCoord() || isGH(); }

    function nuevoConAuditoria() {
      return request.resource.data.creado_por == request.auth.uid
        && request.resource.data.actualizado_por == request.auth.uid;
    }
    function preservaCreador() {
      return request.resource.data.creado_por == resource.data.creado_por
        && request.resource.data.creado_en == resource.data.creado_en
        && request.resource.data.actualizado_por == request.auth.uid;
    }

    // ===== Catálogos =====
    match /empresas/{id} {
      allow read: if signedIn();
      allow create: if (isAdmin() || isGH()) && nuevoConAuditoria();
      allow update: if (isAdmin() || isGH()) && preservaCreador();
      allow delete: if false;
    }
    match /sedes/{id} {
      allow read: if signedIn();
      allow create: if (isAdmin() || isGH()) && nuevoConAuditoria();
      allow update: if (isAdmin() || isGH()) && preservaCreador();
      allow delete: if false;
    }
    match /unidades/{id} {
      allow read: if signedIn();
      allow create: if (isAdmin() || isGH()) && nuevoConAuditoria();
      allow update: if (isAdmin() || isGH()) && preservaCreador();
      allow delete: if false;
    }
    match /cargos_catalogo/{id} {
      allow read: if signedIn();
      // Líder/analista/coord pueden crear cargos al vuelo desde el form
      // "Nueva vacante" cuando el suyo no está en el catálogo. Maribel (GH)
      // refina banda/criticidad después desde /admin/catalogos.
      allow create: if signedIn() && nuevoConAuditoria();
      allow update: if (isAdmin() || isGH()) && preservaCreador();
      allow delete: if false;
    }
    match /festivos/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /plantillas_comunicacion/{id} {
      allow read: if signedIn();
      allow write: if isAdmin() || isGH();
    }
    match /plantillas_graficas/{id} {
      allow read: if signedIn();
      allow write: if isAdmin() || isGH();
    }

    // ===== Usuarios =====
    match /usuarios/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || staff());
      allow create: if isAdmin() && nuevoConAuditoria();
      allow update: if (isAdmin() || request.auth.uid == uid) && preservaCreador();
      allow delete: if false;
    }

    // ===== Contadores (sólo Admin SDK) =====
    match /contadores/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ===== Vacantes =====
    match /vacantes/{id} {
      // get totalmente público (sin requerir login ni Anonymous Auth).
      // Decisión 2026-06-01: la landing pública debe abrirse desde
      // cualquier navegador (normal o incógnito), WhatsApp, móvil, etc.
      // Los datos de la vacante (cargo, salario, justificación) no son
      // PII — están destinados a ser compartidos como oferta de trabajo.
      // Para crear postulación sí se requiere signedIn() (anonymous o
      // identificado), pero LEER la vacante no.
      allow get: if true;
      // list NO tiene resource; cualquier autenticado puede listar,
      // el cliente debe filtrar (ej. lider por lider_uid).
      // Cada doc individual sigue pasando por allow get.
      allow list: if signedIn();
      // El aval ya no es obligatorio al crear — el líder puede mandar la
      // solicitud sin él y queda marcada con aval_pendiente=true para que
      // GH/Coord la gestione después. Política tomada 2026-05-26.
      allow create: if (
        (isLider() && request.resource.data.lider_uid == request.auth.uid)
        || isCoord()
        || isAdmin()
      ) && nuevoConAuditoria()
        && request.resource.data.estado == 'borrador'
        && request.resource.data.aval_url is string;
      allow update: if signedIn() && (
        staff()
        || (isAnalista() && (
              resource.data.analista_uid == null
              || resource.data.analista_uid == request.auth.uid
            ))
      ) && preservaCreador();
      allow delete: if false;
    }

    // ===== Procesos y colecciones derivadas =====
    match /procesos/{id} {
      allow read: if signedIn();
      allow write: if staff() || (isAnalista());
    }
    match /publicaciones/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /candidatos/{id} {
      allow read: if signedIn();
      // Permite que candidatos anónimos creen su registro desde la landing.
      allow create: if signedIn();
      allow update: if staff() || isAnalista();
      allow delete: if false;
    }
    match /postulaciones/{id} {
      allow read: if signedIn();
      // Permite postulación desde landing pública.
      allow create: if signedIn();
      allow update: if staff() || isAnalista();
      allow delete: if false;
    }
    match /contactos_candidato/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /pruebas/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /entrevistas/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista() || (isLider() && resource.data.entrevistador_uid == request.auth.uid);
    }
    match /referencias/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /documentos_candidato/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /informes/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /ternas/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /decisiones/{id} {
      allow read: if signedIn();
      allow create: if isLider() && request.resource.data.lider_uid == request.auth.uid
        || staff();
      allow update, delete: if false;
    }
    match /validaciones_salariales/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /examenes_medicos/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /carpetas_digitales/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /tickets_conexion/{id} {
      allow get: if staff() || isAnalista()
        || (isApoyo() && resource.data.area == request.auth.token.area_apoyo);
      allow list: if staff() || isAnalista() || isApoyo();
      allow create: if staff() || isAnalista();
      allow update: if staff() || isAnalista()
        || (isApoyo() && resource.data.area == request.auth.token.area_apoyo);
      allow delete: if false;
    }

    match /busquedas_sourcing/{id} {
      allow read: if signedIn();
      allow write: if false; // solo Cloud Functions vía Admin SDK
    }

    // ===== Referidos internos (módulo v1, 2026-06-03) =====
    // Auditoría de cada vez que se "activan referidos" para una vacante.
    // Solo escribe la callable generarInvitacionesReferidos.
    match /referidos_generaciones/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    // Mapeo slug → cédula del técnico. get público porque la landing
    // (CarreraPublicaPage) lo resuelve al postular con `?ref=<slug>`.
    // Lo único expuesto es el slug aleatorio — la cédula nunca llega al cliente
    // directamente, viene a través de la callable `resolverRefSlug` que ya
    // valida el slug.
    match /referidos_links/{slug} {
      allow get: if true;
      allow list: if signedIn();
      allow write: if false;
    }
    // Portal del candidato (público, sin login). El cliente NUNCA lee el token
    // directamente: la callable `resolverPortalToken` lo resuelve con Admin SDK.
    // Server-only en ambos sentidos.
    match /portal_candidato_tokens/{token} {
      allow read, write: if false;
    }
    // Documentos que el candidato sube desde su portal. Los escribe la callable
    // registrarDocumentoPortal (Admin SDK); el analista/coordinación los leen.
    match /documentos_portal/{id} {
      allow read: if staff() || isAnalista();
      allow write: if false;
    }
    // Técnicos que pidieron no recibir más invitaciones. Solo admin edita.
    match /referidos_optouts/{cedula} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || isGH();
      allow delete: if isAdmin();
    }
    // Configuración del módulo (Sheet ID, mapping de columnas).
    // Solo 1 doc: `configuracion_global/referidos`.
    match /configuracion_global/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /debida_diligencia/{id} {
      allow read: if signedIn();
      allow create: if isAnalista() || staff();
      allow update: if isAnalista() || staff();
      allow delete: if false;
    }

    match /datos_basicos_integrante/{id} {
      allow read: if signedIn();
      allow create: if isAnalista() || staff();
      allow update: if isAnalista() || staff();
      allow delete: if false;
    }

    match /conceptos_atraccion/{id} {
      allow read: if signedIn();
      allow create: if isAnalista() || staff();
      allow update: if isAnalista() || staff();
      allow delete: if false;
    }

    // ===== Transversales =====
    match /ans_seguimiento/{id} {
      allow read: if signedIn();
      allow write: if staff() || isAnalista();
    }
    match /eventos/{id} {
      allow read: if staff();
      allow create: if signedIn();
      allow update, delete: if false;
    }
    match /notificaciones/{id} {
      allow get: if signedIn() && resource.data.destinatario_uid == request.auth.uid;
      allow list: if signedIn();
      allow update: if signedIn() && resource.data.destinatario_uid == request.auth.uid;
      // staff + analista pueden notificar (ej. el analista avisa al líder que la
      // terna está lista para su revisión). El analista no es staff() pero sí
      // dispara notificaciones legítimas del flujo.
      allow create: if staff() || isAnalista();
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
