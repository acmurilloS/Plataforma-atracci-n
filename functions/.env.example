# Variables de entorno para Cloud Functions (emulador local).
# Copia este archivo a `functions/.env` y rellena los valores reales.
# `functions/.env` está en .gitignore — NUNCA lo commitees.

# Gemini (Google AI Studio)
# Genera una API key gratuita en https://aistudio.google.com/apikey
# Si no se define, la function buscarCandidatosIA usa datos dummy.
GEMINI_API_KEY=
